  PACKAGING
  CONSUMABLE
  FINISHED_GOOD
}

enum WarehouseZone {
  DRY_STORE
  COLD_STORE
  QUARANTINE
  RELEASED
  REJECTED
  PACKAGING
  FINISHED_GOODS
}

model WarehouseLocation {
  id       String        @id @default(cuid())
  code     String        @unique
  label    String
  zone     WarehouseZone
  parentId String?
  parent   WarehouseLocation?  @relation("LocationTree", fields: [parentId], references: [id])
