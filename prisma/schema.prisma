}

enum QcProductCategory {
  CAPSULE
  GUMMY
}

enum QcTestResult {
  PASS
  FAIL
}

/// GMP/TGA-style QC sample traceability: production -> sampling -> laboratory -> retention -> expiry/disposal.
/// sampleId (e.g. QC-2026-000124) is derived from `sequence` at creation time and then stored so it never changes.
model QcSample {
  id       String @id @default(cuid())
  sequence Int    @default(autoincrement()) @unique
  sampleId String @unique

  productName   String
  batchNumber   String
  batchRecordId String?
  batchRecord   BatchRecord? @relation(fields: [batchRecordId], references: [id])

  manufacturingDate DateTime?
  expiryDate        DateTime?

  sampleType      QcSampleType
  productCategory QcProductCategory?
  quantity        Float
  unit            String

  collectedByName String?
  collectionDate  DateTime?
  collectionTime  String?

  productionRoom        String?
  sampleStorageLocation String?

  storageTemperature String?
  storageCondition   String?

  sentToLab          Boolean   @default(false)
  sentDate           DateTime?
  courierOrInternal  String?
  laboratoryName     String?
  laboratoryLocation String?
  receivedByQcName   String?
  receivedDate       DateTime?

  status  QcSampleStatus @default(WAITING_COLLECTION)
  remarks String?

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  labTest         QcLabTest?
  retentionRecord QcRetentionRecord?

  @@index([batchNumber])
  @@index([status])
  @@index([sampleType])
}

/// Header record for a sample's lab testing pass -- the actual checklist rows are QcLabTestItem,
/// generated from the CAPSULE/GUMMY template in qc-sample-defaults.ts for the sample's productCategory.
model QcLabTest {
  id       String   @id @default(cuid())
  sampleId String   @unique
  sample   QcSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  testedByName String?
  testedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items QcLabTestItem[]
}

/// One row of the product-category test checklist (e.g. section "Physical Testing", parameter "Appearance").
model QcLabTestItem {
  id        String    @id @default(cuid())
  labTestId String
  labTest   QcLabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)

  section   String
  parameter String
  result    QcTestResult?
  details   String?
  sortOrder Int

  @@index([labTestId])
}

model QcRetentionRecord {
  id       String   @id @default(cuid())
  sampleId String   @unique
  sample   QcSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  shelf             String?
  cabinet           String?
  boxNumber         String?
  position          String?
  quantityRemaining Float?
  opened            Boolean   @default(false)
  lastChecked       DateTime?
  expiryDate        DateTime?
  destroyDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiryDate])
}

enum MfgBatchStatus {
  IN_PROGRESS
  COMPLETED
}

enum MfgMaterialGroup {
  RAW_INGREDIENT
  RAW_ACTIVE_INGREDIENT
  RAW_EXCIPIENT
  PACKAGING_EMPTY_CAPSULE
  PACKAGING_EMPTY_BOTTLE
  PACKAGING_CAP
  PACKAGING_DESICCANT
  PACKAGING_LABEL
  PACKAGING_CARTON
  PACKAGING_INSERT
  PACKAGING_SHRINK_WRAP
  PACKAGING_SHIPPER
  PACKAGING_PALLET
}

enum MfgPackagingMaterialType {
  LABEL
  CARTON
  INSERT
  SHRINK_WRAP
  SHIPPER
}

/// End-to-end GMP/TGA-style manufacturing reconciliation: Warehouse Issue -> Blending -> Encapsulation
/// -> Bottling -> X-Ray/Metal Detection -> Packaging -> Finished Goods Warehouse -> Dispatch. Each stage
/// is its own record, filled in independently as production reaches it. Balance/yield figures (Quantity
/// Balance, Blend Yield %, Capsule Yield %, etc.) are computed at render time from the raw quantities
/// stored here -- never persisted -- matching the existing yield% precedent in batch-record-client.tsx.
model MfgBatch {
  id            String       @id @default(cuid())
  batchNumber   String
  productName   String
  batchRecordId String?
  batchRecord   BatchRecord? @relation(fields: [batchRecordId], references: [id])

  status  MfgBatchStatus @default(IN_PROGRESS)
  remarks String?

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  warehouseIssue         MfgWarehouseIssue?
  blending               MfgBlending?
  encapsulation          MfgEncapsulation?
  bottling               MfgBottling?
  xrayInspection         MfgXrayInspection?
  packaging              MfgPackaging?
  finishedGoodsWarehouse MfgFinishedGoodsWarehouse?
  dispatchEvents         MfgDispatchEvent[]

  @@index([batchNumber])
  @@index([status])
}

model MfgWarehouseIssue {
  id         String   @id @default(cuid())
  mfgBatchId String   @unique
  mfgBatch   MfgBatch @relation(fields: [mfgBatchId], references: [id], onDelete: Cascade)

  issuedByName String?
  issueDate    DateTime?
  remarks      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines MfgMaterialIssueLine[]
}

/// One row per material issued for a batch -- raw material or packaging material, discriminated by
/// materialGroup. New batches pre-populate one line per material type from a default template in
/// mfg-reconciliation-defaults.ts, the same way QcLabTestItem rows are seeded from a checklist template.
model MfgMaterialIssueLine {
  id               String            @id @default(cuid())
  warehouseIssueId String
  warehouseIssue   MfgWarehouseIssue @relation(fields: [warehouseIssueId], references: [id], onDelete: Cascade)

  materialGroup     MfgMaterialGroup
  materialCode      String?
  description       String
  supplier          String?
  lotBatchNumber    String?
  expiryDate        DateTime?
  quantityRequested Float?
  quantityIssued    Float?
  quantityReturned  Float?
  sortOrder         Int

  @@index([warehouseIssueId])
}

model MfgBlending {
  id         String   @id @default(cuid())
  mfgBatchId String   @unique
  mfgBatch   MfgBatch @relation(fields: [mfgBatchId], references: [id], onDelete: Cascade)

  totalTheoreticalWeightKg Float?
  actualWeightKg           Float?
  blendBatchNumber         String?

  powderRemainingKg     Float?
  blenderResidueKg      Float?
  sieveLossKg           Float?
  dustLossKg            Float?
  spillagesKg           Float?
  qcSamplesQty          Float?
  retentionSamplesQty   Float?
  destroyedMaterialKg   Float?
  returnedToWarehouseKg Float?

  totalBlendProducedKg Float?

  blendedByName String?
  blendedAt     DateTime?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MfgEncapsulation {
  id         String   @id @default(cuid())
