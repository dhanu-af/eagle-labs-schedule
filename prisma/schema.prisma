generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  TEAM_LEAD
  QA
  EMPLOYEE
  OPERATIONS
  OTHERS
}

enum PayRunStatus {
  DRAFT
  FINALIZED
}

enum TaskStatus {
  NOT_STARTED
  RUNNING
  COMPLETED
  DELAYED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KbCategory {
  BLENDING_SOP
  MACHINE_TROUBLESHOOTING
  MAINTENANCE_CLEANING
  SAFETY
  PARTS
  QUALITY_CONTROL
  QUALITY_ASSURANCE
  HACCP
  SQF
  GMP
  GDP
  FOOD_SAFETY
  MANUAL_HANDLING
  RAW_MATERIALS_INGREDIENTS
  FORMULATIONS
  PRODUCTION
  PACKAGING
  EQUIPMENT_MAINTENANCE
  CLEANING_SANITATION
  ENVIRONMENTAL_MONITORING
  WHS
  TEAMWORK_COMMUNICATION
  TRAINING_INDUCTION
  SOPS
  POLICIES_PROCEDURES
}

enum LoginStatus {
  SUCCESS
  FAILED
}

enum CheckStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
}

enum CleaningType {
  FULL_CLEAN
  PROVISIONAL_CLEAN
}

enum PostOpItem {
  BLENDING_ROOM
  V_BLENDER_1
  V_BLENDER_2
  CAPSULE_ROOM
  CAPSULE_EQUIPMENT
  CAPSULE_MACHINE
}

enum EnvArea {
  BLENDING_ROOM
  CAPSULE_ROOM
}

enum WorkLogRoom {
  ENCAPSULATION_ROOM
  BLENDING_ROOM
}

enum WorkLogActivity {
  ENCAPSULATION
  DISPENSING_MIXING
  GUMMY_POLISHING
  SORTING_REWORK
  PACKING
  GUMMY_COATING
  POLISHING
  SET_UP
  TESTING
  CLEANING_PROVISIONAL
  CLEANING_FULL
  OTHERS
  BREAKDOWN
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  employees        Employee[]
  dailyTasks       DailyTask[]
  weeklyAssignments WeeklyAssignment[]
  kpis             Kpi[]
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  photoUrl    String?
  role        Role     @default(EMPLOYEE)
  shift       String   @default("Day")
  phone       String?
  email       String?  @unique
  teamId      String
  active      Boolean  @default(true)
  leaveBalance Int     @default(20)
  hourlyRate  Float    @default(0)
  createdAt   DateTime @default(now())

  team             Team               @relation(fields: [teamId], references: [id])
  user             User?
  dailyTasks       DailyTask[]        @relation("assignee")
  weeklyAssignments WeeklyAssignment[]
  kpiRecords       KpiRecord[]
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]      @relation("requester")
  approvedLeaves   LeaveRequest[]      @relation("approver")
  statusUpdates    DailyTask[]        @relation("updatedBy")
  payslips         Payslip[]
  notifications    Notification[]

  @@index([teamId])
}

model User {
  id                  String   @id @default(cuid())
  username            String   @unique
  passwordHash        String
  role                Role     @default(EMPLOYEE)
  fullName            String
  department          String?
  employeeId          String?  @unique
  isPermanent         Boolean  @default(false)
  disabled            Boolean  @default(false)
  mustChangePassword  Boolean  @default(false)
  failedLoginAttempts Int      @default(0)
  locked              Boolean  @default(false)
  ingredientLibraryAccess Boolean @default(false)
  createdAt           DateTime @default(now())
  lastActiveAt        DateTime?

  employee    Employee?    @relation(fields: [employeeId], references: [id])
  loginEvents LoginEvent[]
}

model LoginEvent {
  id        String      @id @default(cuid())
  userId    String?
  username  String
  fullName  String?
  role      Role?
  loginAt   DateTime    @default(now())
  logoutAt  DateTime?
  status    LoginStatus
  ipAddress String?
  userAgent String?

  user User? @relation(fields: [userId], references: [id])

  @@index([loginAt])
  @@index([userId])
}

model DailyTask {
  id            String     @id @default(cuid())
  date          DateTime
  teamId        String
  employeeId    String?
  product       String
  batchNo       String?
  process       String
  targetQty     Float?
  targetUnit    String     @default("kg")
  actualQty     Float      @default(0)
  plannedStart  String?
  plannedFinish String?
  priority      Priority   @default(MEDIUM)
  status        TaskStatus @default(NOT_STARTED)
  delayReason   String?
  notes         String?
  updatedById   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  team       Team      @relation(fields: [teamId], references: [id])
  employee   Employee? @relation("assignee", fields: [employeeId], references: [id])
  updatedBy  Employee? @relation("updatedBy", fields: [updatedById], references: [id])

  @@index([date])
  @@index([teamId, date])
}

model WeeklyAssignment {
  id         String   @id @default(cuid())
  weekStart  DateTime
  dayOfWeek  Int
  teamId     String
  employeeId String
  task       String
  hours      Float    @default(8)
  createdAt  DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([weekStart, teamId])
}

model Kpi {
  id       String  @id @default(cuid())
  teamId   String
  product  String?
  name     String
  unit     String  @default("kg")
  target   Float

  team          Team             @relation(fields: [teamId], references: [id])
  records       KpiRecord[]
  dailyTargets  KpiDailyTarget[]
}

model KpiDailyTarget {
  id     String   @id @default(cuid())
  kpiId  String
  date   DateTime
  target Float

  kpi Kpi @relation(fields: [kpiId], references: [id])

  @@unique([kpiId, date])
  @@index([date])
}

model KpiRecord {
  id         String   @id @default(cuid())
  kpiId      String
  employeeId String?
  date       DateTime
  actual     Float    @default(0)
  createdAt  DateTime @default(now())

  kpi      Kpi       @relation(fields: [kpiId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([date])
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  date       DateTime
  status     AttendanceStatus @default(PRESENT)
  hoursWorked Float           @default(8)
  overtime   Float            @default(0)
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  startDate   DateTime
  endDate     DateTime
  type        String      @default("Annual")
  reason      String?
  status      LeaveStatus @default(PENDING)
  approverId  String?
  createdAt   DateTime    @default(now())

  employee Employee  @relation("requester", fields: [employeeId], references: [id])
  approver Employee? @relation("approver", fields: [approverId], references: [id])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  message    String
  authorId   String?
  authorName String?
  authorRole Role?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String
  actorRole  Role
  action     String
  entityType String
  entityId   String?
  summary    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  message    String
  type       String
  link       String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, read])
}

model PayRun {
  id           String       @id @default(cuid())
  periodStart  DateTime
  periodEnd    DateTime
  status       PayRunStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  finalizedAt  DateTime?

  payslips Payslip[]
}

model Payslip {
  id             String  @id @default(cuid())
  payRunId       String
  employeeId     String
  regularHours   Float   @default(0)
  overtimeHours  Float   @default(0)
  hourlyRate     Float   @default(0)
  grossPay       Float   @default(0)
  notes          String?

  payRun   PayRun   @relation(fields: [payRunId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([payRunId, employeeId])
}

model KnowledgeEntry {
  id        String     @id @default(cuid())
  category  KbCategory
  title     String
  keywords  String
  cause     String?
  answer    String
  source    String?
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([category])
}

model KbQuestionLog {
  id          String   @id @default(cuid())
  question    String
  matchedId   String?
  matchTitle  String?
  matchScore  Float?
  askedByName String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Ingredient {
  id                String   @id @default(cuid())
  name              String
  alternateName     String?
  type              String
  category          String?
  aanLabel          String?
  aanValue          String?
  notes             String?
  verified          Boolean  @default(false)
  verificationSource String?
  verifiedAt        DateTime?
  verifiedBy        String?
  classification    String?
  mainBenefit       String?
  usedFor           String?
  synonyms          String?
  chemicalName      String?
  casNumber         String?
  molecularFormula  String?
  molecularWeight   String?

  // Per-authority regulatory status — leave blank ("—") unless confirmed
  tgaStatus         String?
  apvmaStatus       String?
  fdaStatus         String?
  emaStatus         String?
  aicisStatus       String?
  regulatoryStatus  String?

  // Applications
  primaryUse        String?
  industry          String?
  productTypes      String?

  typicalDosage     String?
  storageConditions String?
  shelfLife         String?

  // Safety
  safetyNotes       String?
  ghsClassification String?
  signalWord        String?
  ppe               String?
  handlingPrecautions String?

  manufacturingNotes String?

  // Quality specifications
  qcNotes           String?
  qcIdentity        String?
  qcAssay           String?
  qcMoisture        String?
  qcHeavyMetals     String?
  qcMicrobialLimits String?

  // Physical properties
  appearance        String?
  colour            String?
  odour             String?
  solubility        String?
  density           String?
  meltingPoint      String?
  phValue           String?

  relatedIngredientsText String?
  referencesText    String?

  faq               String?
  source            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([type])
  @@index([category])
}

model SupervisorPreOpCheck {
  id                 String      @id @default(cuid())
  date               DateTime
  room               String
  roomCleanliness    Boolean     @default(false)
  equipmentReadiness Boolean     @default(false)
  safetyPpeVerified  Boolean     @default(false)
  calibrationStatus  String?
  comments           String?
  status             CheckStatus @default(COMPLETED)
  locked             Boolean     @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([room])
}

model QaPreOpCheck {
  id                     String      @id @default(cuid())
  date                   DateTime
  room                   String
  qaRoomInspection       Boolean     @default(false)
  equipmentVerification  Boolean     @default(false)
  gmpCompliance          Boolean     @default(false)
  environmentalCondition Boolean     @default(false)
  comments               String?
  status                 CheckStatus @default(COMPLETED)
  locked                 Boolean     @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([room])
}

model EnvironmentalCheck {
  id          String      @id @default(cuid())
  date        DateTime
  area        EnvArea
  temperature Float
  humidity    Float
  passFail    Boolean
  remarks     String?
  status      CheckStatus @default(PENDING)
  locked      Boolean     @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  supervisorApprovedById   String?
  supervisorApprovedByName String?
  supervisorApprovedAt     DateTime?

  qaApprovedById   String?
  qaApprovedByName String?
  qaApprovedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([area])
}

model EnvironmentalLimit {
  id        String   @id @default(cuid())
  area      EnvArea  @unique
  minTemp   Float
  maxTemp   Float
  minRH     Float
  maxRH     Float
  updatedAt DateTime @updatedAt
}

model LineClearance {
  id                    String      @id @default(cuid())
  date                  DateTime
  line                  String
  previousProductName   String?
  previousBatchNumber   String?
  previousBatchCleared  Boolean     @default(false)
  materialCleared       Boolean     @default(false)
  labelPackagingCleared Boolean     @default(false)
  equipmentCleared      Boolean     @default(false)
  documentationVerified Boolean     @default(false)
  comments              String?
  status                CheckStatus @default(PENDING)
  locked                Boolean     @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  supervisorApprovedById   String?
  supervisorApprovedByName String?
  supervisorApprovedAt     DateTime?

  qaApprovedById   String?
  qaApprovedByName String?
  qaApprovedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model PostOpCheck {
  id                         String       @id @default(cuid())
  date                       DateTime
  item                       PostOpItem
  previousProductName        String?
  previousBatchNumber        String?
  cleaningType               CleaningType
  cleaningVerificationStatus String?
  comments                   String?
  status                     CheckStatus  @default(PENDING)
  locked                     Boolean      @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  verifiedById   String?
  verifiedByName String?
  verifiedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([item])
}

model WorkLog {
  id             String          @id @default(cuid())
  room           WorkLogRoom
  opName         String
  startDate      DateTime
  startTime      String
  productName    String
  productCode    String
  batchNumber    String
  activity       WorkLogActivity
  activityOther  String?
  endDate        DateTime?
  endTime        String?
  closingOpName  String?
  comments       String?
  status         CheckStatus     @default(PENDING)
  locked         Boolean         @default(false)

  submittedById   String
  submittedByName String
  submittedByRole Role
  submittedAt     DateTime @default(now())
  signature       String

  supervisorApprovedById   String?
  supervisorApprovedByName String?
  supervisorApprovedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([room])
}

model CheckAttachment {
  id         String   @id @default(cuid())
  checkType  String
  checkId    String
  url        String
  fileName   String
  uploadedAt DateTime @default(now())

  @@index([checkType, checkId])
}

model ChatMessage {
  id         String    @id @default(cuid())
  authorId   String?
  authorName String
  authorRole Role
  message    String
  editedAt   DateTime?
  createdAt  DateTime  @default(now())

  replyToId String?
  replyTo   ChatMessage?  @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("ChatReplies")
  reactions ChatReaction[]

  @@index([createdAt])
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

/// One row per user — tracks how far into the shared chat room they've read.
model ChatReceipt {
  userId     String   @id
  lastReadAt DateTime @default(now())
}

/// One row per user — presence of an active "typing…" state, expires by age (no cleanup job needed).
model ChatTyping {
  userId    String   @id
  userName  String
  updatedAt DateTime @default(now())
}

model FormulationFolder {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  formulations Formulation[]
}

model Formulation {
  id            String   @id @default(cuid())
  folderId      String
  productName   String
  baseBatchSize Float
  baseUnit      String   @default("kg")
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  folder      FormulationFolder       @relation(fields: [folderId], references: [id])
  ingredients FormulationIngredient[]

  @@index([folderId])
}

model FormulationIngredient {
  id               String  @id @default(cuid())
  formulationId    String
  order            Int
  rmNumber         String?
  ingredientName   String
  uin              String?
  baseQty          Float
  controlStatus    String?
  changeControlRef String?
  approvedBy       String?
  comments         String?
  tolerancePct     Float   @default(2)

  formulation Formulation @relation(fields: [formulationId], references: [id], onDelete: Cascade)

  @@index([formulationId])
}
