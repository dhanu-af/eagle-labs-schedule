# Local dev default. For Supabase, use the Postgres connection string from
# Project Settings > Database > Connection string, and change the
# `provider` in prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:./dev.db"

# Random secret used to sign session cookies (jose/HS256). Generate a real
# one for production, e.g.: openssl rand -base64 32
SESSION_SECRET="change-me-before-deploying"
